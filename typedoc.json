{
  "plugin": ["typedoc-plugin-markdown"],
  "out": "docs/api",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.json",
  "readme": "none",
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "parametersFormat": "table",
  "propertyMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "useCodeBlocks": true,
  "textContentMappings": {
    "body.anyVersion": ""
  }
}
