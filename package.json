{
  "name": "cesium-utils-lib",
  "version": "1.0.0",
  "description": "Cesium utility functions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:gen": "typedoc && bun run scripts/consolidate.mjs",
    "docs:dev": "typedoc && bun run scripts/consolidate.mjs && vitepress dev docs",
    "docs:build": "typedoc && bun run scripts/consolidate.mjs && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "cesium": "^1.100.0"
  },
  "devDependencies": {
    "cesium": "^1.100.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4"
  }
}