  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "cesium": "^1.100.0"
  },
  "devDependencies": {
    "cesium": "^1.100.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}